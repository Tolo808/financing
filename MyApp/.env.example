# Copy to .env once the Supabase project exists (see the top-level README "Supabase setup"
# section). EXPO_PUBLIC_ vars are inlined at build time and safe to ship in the app bundle —
# the anon key is meant to be public; RLS policies are what actually restrict access.
EXPO_PUBLIC_SUPABASE_URL=""
EXPO_PUBLIC_SUPABASE_ANON_KEY=""
