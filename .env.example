# Copy this to admin/.env and fill in real values.
# DIRECT_URL is used by the Prisma CLI for migrations; DATABASE_URL is used by the running app
# (src/server/db.ts).
#
# On Supabase, use the SHARED POOLER host (aws-*.pooler.supabase.com), not the direct
# db.<project-ref>.supabase.co host — the direct host is IPv6-only on most project tiers and
# will fail to connect ("Can't reach database server") from any IPv4-only network. Get both
# strings from the dashboard's "Connect" button -> ORMs -> Prisma:
#   DATABASE_URL = transaction-mode pooler, port 6543, add "?pgbouncer=true"
#   DIRECT_URL   = session-mode pooler, port 5432
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres"

# Supabase — Project Settings -> API. Auth (admin + driver) runs entirely on Supabase Auth.
# NEXT_PUBLIC_* values are safe to expose to the browser/Expo app; SUPABASE_SERVICE_ROLE_KEY
# must never be exposed client-side — server-only, used for admin/driver account creation.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
